<div>
  <h1> New game </h1>
  <div id="letters-container">
  <% @letters.each do |letter| %>
    <div class="letter-card"><%= letter.capitalize %></div>
  <% end %>
  </div>
  <div class="mt-3">
    <form action="score" method="post" data-turbo="false">
      <label for="word" class="form-label">What is the longest word you can find?</label>
      <div class="input-group my-3">
      <input type="text" class="form-control" id="word" name="word" aria-describedby="basic-addon2">
      <input type="hidden" name="letters" value=<%=@letters%>>
        <div class="input-group-append">
          <button class="btn btn-primary px-3" type="submit">Play</button>
        </div>
    </div>
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    </form>
  </div>
</div>
